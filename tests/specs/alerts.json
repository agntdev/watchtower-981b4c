[
  {
    "name": "Alerts menu when empty",
    "steps": [
      {
        "send": { "callback": "alerts:menu", "userId": 2 },
        "expect": [
          {
            "method": "sendMessage",
            "payload": {
              "text": "No alerts set yet. Add a coin to your watchlist, then tap 🔔 to set an alert."
            }
          }
        ]
      }
    ]
  },
  {
    "name": "Set threshold alert flow",
    "steps": [
      {
        "send": { "callback": "add_ticker:BTC", "userId": 3 },
        "expect": [
          { "method": "sendMessage", "payload": { "text": "✅ BTC added to your watchlist with default settings." } }
        ]
      },
      {
        "send": { "callback": "set_threshold:BTC", "userId": 3 },
        "expect": [
          { "method": "sendMessage", "payload": { "text": "Set an alert for BTC. Should I alert you when the price goes above or below a target?" } }
        ]
      },
      {
        "send": { "callback": "alert_dir:BTC:above", "userId": 3 },
        "expect": [
          { "method": "sendMessage", "payload": { "text": "Got it — alert when BTC goes above a target price. What price should I watch for?" } }
        ]
      },
      {
        "send": { "text": "50000", "userId": 3 },
        "expect": [
          { "method": "sendMessage", "payload": { "text": "✅ Alert set: BTC above $50,000.00" } }
        ]
      }
    ]
  }
]
